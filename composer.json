{
  "name": "arifje/craft-delete-cache-key",
  "description": "Search and clear Craft CMS cache entries by key, wildcard, or cache tag.",
  "version": "1.0.0",
  "type": "craft-plugin",
  "license": "MIT",
  "keywords": [
    "craft",
    "craftcms",
    "cache",
    "cache-key",
    "cache-tags"
  ],
  "support": {
    "issues": "https://github.com/arifje/craft-delete-cache-key/issues",
    "source": "https://github.com/arifje/craft-delete-cache-key",
    "docs": "https://github.com/arifje/craft-delete-cache-key/blob/main/README.md"
  },
  "require": {
    "php": ">=8.0.2",
    "craftcms/cms": "^4.0 || ^5.0"
  },
  "autoload": {
    "psr-4": {
      "arifje\\deletecachekey\\": "src/"
    }
  },
  "extra": {
    "name": "Delete Cache Key",
    "handle": "delete-cache-key",
    "class": "arifje\\deletecachekey\\Plugin"
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
